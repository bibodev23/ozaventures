# Production defaults for https://oz.webmove.fr.
# Copy this file to .env.prod.local or pass it with:
# docker compose --env-file .env.prod.local -f compose.yaml -f compose.prod.yaml up -d --build --wait
#
# Never commit the real .env.prod.local file.

APP_ENV=prod
APP_DEBUG=0

# Webapp + API public URL
SERVER_NAME=oz.webmove.fr
DEFAULT_URI=https://oz.webmove.fr
CADDY_MERCURE_PUBLIC_URL=https://oz.webmove.fr/.well-known/mercure

# Generate strong values on the VPS:
# openssl rand -hex 32
APP_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
CADDY_MERCURE_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# First director account bootstrap.
# After deployment + migrations, run:
# docker compose --env-file .env.prod.local -f compose.yaml -f compose.prod.yaml exec php php bin/console app:user:create-director
APP_INITIAL_DIRECTOR_USERNAME=directrice
APP_INITIAL_DIRECTOR_PASSWORD=CHANGE_ME_FIRST_DIRECTOR_PASSWORD
APP_INITIAL_DIRECTOR_FIRST_NAME=Directrice
APP_INITIAL_DIRECTOR_LAST_NAME=OZ

# Database used by the Symfony Docker stack
POSTGRES_DB=oz
POSTGRES_USER=oz
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_VERSION=16
POSTGRES_CHARSET=utf8
