<div{{ attributes.defaults({class: 'global-search-live'}) }}>
    <label class="global-search-field">
        <span class="global-search-mark" aria-hidden="true">S</span>
        <select
            class="global-search-select"
            aria-label="Rechercher un enfant, un animateur ou une sortie"
            data-controller="symfony--ux-autocomplete--autocomplete global-search"
            data-symfony--ux-autocomplete--autocomplete-url-value="{{ path('app_global_search_autocomplete') }}"
            data-symfony--ux-autocomplete--autocomplete-min-characters-value="2"
            data-symfony--ux-autocomplete--autocomplete-preload-value="false"
            data-symfony--ux-autocomplete--autocomplete-no-results-found-text-value="Aucun résultat"
            data-symfony--ux-autocomplete--autocomplete-loading-more-text-value="Recherche en cours..."
            data-symfony--ux-autocomplete--autocomplete-no-more-results-text-value="Fin des résultats"
            data-symfony--ux-autocomplete--autocomplete-tom-select-options-value="{{ {
                placeholder: 'Rechercher une sortie, un enfant, un animateur...',
                maxOptions: 12,
                persist: false
            }|json_encode|e('html_attr') }}"
        >
            <option value=""></option>
        </select>
        <kbd>Ctrl F</kbd>
    </label>
</div>
