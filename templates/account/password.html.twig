{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block body %}
    <section class="page-heading">
        <div>
            <p class="eyebrow">Compte animateur</p>
            <h1>Changer mon mot de passe</h1>
        </div>
    </section>

    <section class="form-panel">
        <div class="hint-card">
            <strong>{{ animator.fullName }}</strong>
            <span>Identifiant : {{ animator.username }}</span>
            {% if animator.mustChangePassword %}
                <p>La direction t'a donné un mot de passe initial. Choisis maintenant ton propre mot de passe.</p>
            {% endif %}
        </div>

        {{ form_start(form, {attr: {class: 'form'}}) }}
            {{ form_row(form.currentPassword) }}
            {{ form_row(form.newPassword) }}
            <div class="form-actions">
                <button class="button button-primary" type="submit">Modifier mon mot de passe</button>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
