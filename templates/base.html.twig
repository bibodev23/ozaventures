<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Centre aéré{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}?v=20260529-turbo">
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body>
        {% set current_route = app.request.attributes.get('_route') %}
        <a class="skip-link" href="#content">Aller au contenu</a>

        <div class="{{ app.user ? 'app-shell' : 'auth-shell' }}">
            {% if app.user %}
                <aside class="app-sidebar">
                    <a class="brand" href="{{ path('app_dashboard') }}">
                        <span class="brand-mark">OZ</span>
                        <span>
                            <strong>Oz'Aventure</strong>
                            <small>Pilotage direction</small>
                        </span>
                    </a>

                    <div class="sidebar-section">
                        <p class="sidebar-label">Menu</p>
                        <nav class="nav" aria-label="Navigation principale">
                            {% if is_granted('ROLE_DIRECTOR') %}
                                {% set nav_items = [
                                    {label: 'Dashboard', icon: 'DB', route: 'app_dashboard', routes: ['app_home', 'app_dashboard']},
                                    {label: 'Planning', icon: 'PL', route: 'app_daily_planning', match: 'app_daily_planning'},
                                    {label: 'Horaires', icon: 'HR', route: 'app_work_schedule', match: 'app_work_schedule'},
                                    {label: 'Sorties', icon: 'SO', route: 'app_outings', match: 'app_outing'},
                                    {label: 'Enfants', icon: 'EN', route: 'app_children', match: 'app_child'},
                                    {label: 'Animateurs', icon: 'AN', route: 'app_animators', match: 'app_animator'},
                                    {label: 'Direction', icon: 'DI', route: 'app_directors', match: 'app_director'}
                                ] %}
                                {% for item in nav_items %}
                                    {% set is_active = item.routes is defined ? current_route in item.routes : current_route starts with item.match %}
                                    <a
                                        class="{{ is_active ? 'is-active' : '' }}"
                                        href="{{ path(item.route) }}"
                                        data-turbo-preload
                                        {% if is_active %}aria-current="page"{% endif %}
                                    >
                                        <span class="nav-icon">{{ item.icon }}</span>
                                        <span>{{ item.label }}</span>
                                    </a>
                                {% endfor %}
                            {% elseif is_granted('ROLE_ANIMATOR') %}
                                <a class="{{ current_route starts with 'app_account' ? 'is-active' : '' }}" href="{{ path('app_account_password') }}">
                                    <span class="nav-icon">MP</span>
                                    <span>Mot de passe</span>
                                </a>
                            {% endif %}
                        </nav>
                    </div>

                    <div class="sidebar-section sidebar-section-bottom">
                        <p class="sidebar-label">General</p>
                        <a class="sidebar-link" href="#content"><span class="nav-icon">HP</span>Aide</a>
                        <a class="sidebar-link" href="{{ path('app_logout') }}"><span class="nav-icon">LO</span>Déconnexion</a>
                    </div>

                </aside>

                <div class="app-workspace">
                    <header class="workspace-topbar">
                        {% if is_granted('ROLE_DIRECTOR') %}
                            <twig:GlobalSearch />
                        {% else %}
                            <div class="search-pill" aria-label="Recherche visuelle">
                                <span>S</span>
                                <span>Rechercher une sortie, un enfant...</span>
                                <kbd>Ctrl F</kbd>
                            </div>
                        {% endif %}
                        <div class="workspace-actions">
                            <span class="round-action">@</span>
                            <span class="round-action">!</span>
                            <span class="user-chip">
                                <span class="avatar">{{ app.user.userIdentifier|slice(0, 2)|upper }}</span>
                                <span>
                                    <strong>{{ app.user.userIdentifier }}</strong>
                                    <small>Compte connecté</small>
                                </span>
                            </span>
                        </div>
                    </header>
            {% endif %}

            <main id="content" class="page {{ app.user ? '' : 'auth-page' }}">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash flash-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </main>

            {% if app.user %}
                </div>
            {% endif %}
        </div>

        {% block floating_actions %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </body>
</html>
